{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": null,
  "devCommand": "pnpm dev",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "JWT_SECRET": "@jwt_secret",
    "OWNER_NAME": "@owner_name"
  },
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
